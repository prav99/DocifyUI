# Client build-time config (Vite). Only VITE_-prefixed vars are exposed to the
# browser bundle — never put secrets here.

# Public support address shown across the site as mailto: links and help text.
# Defaults to support@docifydocai.com if unset (see client/src/config.js).
VITE_SUPPORT_EMAIL="support@docifydocai.com"
