generator client {
  provider = "prisma-client-js"
}

// PRODUCTION schema (Railway / Postgres). Model blocks MUST stay identical to
// prisma/schema.prisma (the SQLite local-dev schema). Deployed via:
//   npx prisma db push --schema=prisma/schema.postgres.prisma
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String       @default("")
  passwordHash  String?
  emailVerified Boolean      @default(false)
  otpHash       String       @default("") // bcrypt hash of the current signup OTP
  otpExpires    DateTime?
  otpAttempts   Int          @default(0)
  oauthProvider String?
  plan          String       @default("free")
  billingCycle  String       @default("annual")
  seats         Int          @default(5)
  taxId         String       @default("")
  createdAt     DateTime     @default(now())
  sources       Source[]
  generations   Generation[]
  members       TeamMember[]
  automation    Automation?
  profiles      AutomationProfile[]
  syncDocs      SyncDoc[]
}

model Source {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String
  detail       String    @default("")
  token        String    @default("") // OAuth access token or API token. Encrypt at rest in production.
  refreshToken String    @default("") // For providers with expiring tokens (GitLab, Bitbucket).
  expiresAt    DateTime? // Access-token expiry; null = non-expiring (GitHub, API tokens).
  status       String    @default("connected")
  createdAt DateTime @default(now())
}

model Generation {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  repo         String
  branch       String         @default("main")
  provider     String         @default("github") // code host the repo lives on
  aiDocs       String         @default("[]") // JSON [[docType, sections]] from real AI generation
  track        String
  docTypes     String // JSON array of ids
  format       String
  instructions String         @default("")
  files        String         @default("[]") // JSON array of filenames
  skillName    String         @default("") // Uploaded SKILL.md filename
  skill        String         @default("") // SKILL.md content — parsed and applied at generation time
  brief        String         @default("{}") // Marketing brief JSON: audience, emphasis, tone
  output       String         @default("{}") // Output options JSON: cover, TOC, watermark, legal, branding…
  status       String         @default("queued") // queued | running | complete | failed
  step         Int            @default(0)
  steps        String         @default("[]") // JSON array of step labels
  title        String         @default("")
  content      String         @default("")
  preview      String         @default("") // rendered HTML preview honoring all output options
  score        Int            @default(0)
  // Import History lifecycle: draft | review | approved | published.
  approval     String         @default("draft")
  approvedAt   DateTime?
  createdAt    DateTime       @default(now())
  report       QualityReport?
}

// Import History: a snapshot of a generated document each time regeneration
// replaces its content — full version history with compare and restore.
model DocVersion {
  id           String   @id @default(cuid())
  userId       String
  generationId String
  version      Int
  title        String   @default("")
  content      String   @default("")
  aiDocs       String   @default("[]")
  score        Int      @default(0)
  note         String   @default("")
  createdAt    DateTime @default(now())

  @@index([generationId])
}

model QualityReport {
  id           String     @id @default(cuid())
  generationId String     @unique
  generation   Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)
  issues       String // JSON array
  links        String // JSON array
  style        String // JSON array
  fixedIds     String     @default("[]") // JSON array of resolved issue ids
  createdAt    DateTime   @default(now())
}

model TeamMember {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name      String   @default("")
  email     String
  role      String   @default("Writer")
  status    String   @default("active") // active | invited
  createdAt DateTime @default(now())
}

model Automation {
  id      String  @id @default(cuid())
  userId  String  @unique
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  enabled Boolean @default(true)
  branch  String  @default("main")
  gate    Int     @default(85)
  secret  String  @default("") // HMAC webhook secret — generated on first use, rotatable
  runs    String  @default("[]") // JSON run history (latest 20): trigger, commit, score, gate result
}

// A reusable automation pipeline: the full 6-step wizard configuration plus
// its own webhook secret and execution history. A user can run many profiles
// (different repos, branches, document sets) side by side.
model AutomationProfile {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String   @default("Documentation pipeline")
  status    String   @default("active") // active | paused
  secret    String   @default("")
  config    String   @default("{}") // wizard steps 1–6 as JSON (see PROFILE_DEFAULTS in api.js)
  runs      String   @default("[]") // execution history, newest first (capped)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ Doc sync: AI-maintained existing documentation ============
// SyncDoc     — an uploaded baseline document (full text + parsed outline +
//               semantic profile). The placement target for commit-driven updates.
// SyncUpdate  — one AI-proposed change to a SyncDoc, tied to a commit: target
//               section, confidence, reasoning, side-by-side diff, review status.
// SyncVersion — immutable snapshot of a SyncDoc created on upload, on every
//               approved update, and on restore.

model SyncDoc {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  format    String   @default("markdown") // markdown | html | docx | pdf | confluence | notion | git
  repo      String   @default("") // mapped repository (owner/name)
  branch    String   @default("main")
  content   String   @default("") // canonical extracted text
  docsProvider String @default("") // set when the doc was imported from a docs repository
  docsRepo     String @default("") // docs repository (owner/name) — may differ from the code repo
  docsBranch   String @default("")
  docsPath     String @default("") // path of the source file inside the docs repository
  sections  String   @default("[]") // parsed outline JSON [{level,title,line,num?}]
  profile   String   @default("{}") // semantic profile JSON: terminology, style, glossary, stats
  status    String   @default("parsing") // parsing | indexing | ready | failed
  progress  Int      @default(0) // 0–100 during parsing/indexing
  error     String   @default("")
  cursor    Int      @default(0) // position in the repo's commit feed already synchronized
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  versions  SyncVersion[]
  updates   SyncUpdate[]
}

model SyncVersion {
  id        String   @id @default(cuid())
  docId     String
  doc       SyncDoc  @relation(fields: [docId], references: [id], onDelete: Cascade)
  number    Int
  source    String   @default("upload") // upload | ai-update | restore | edit
  commit    String   @default("")
  summary   String   @default("")
  content   String   @default("")
  createdAt DateTime @default(now())
}

model SyncUpdate {
  id            String    @id @default(cuid())
  userId        String
  docId         String
  doc           SyncDoc   @relation(fields: [docId], references: [id], onDelete: Cascade)
  commit        String
  message       String    @default("")
  branch        String    @default("main")
  author        String    @default("")
  files         String    @default("[]") // changed files JSON
  kind          String    @default("update-existing") // update-existing | insert-new
  anchor        String    @default("{}") // JSON {title, anchorPath, line, page, level}
  confidence    Int       @default(0)
  reasoning     String    @default("{}") // JSON {why, semantic, signals, candidates}
  diff          String    @default("{}") // JSON {startLine, before:[], after:[]}
  snippet       String    @default("") // AI-generated content (editable before approval)
  status        String    @default("pending") // pending | approved | rejected
  decidedAt     DateTime?
  versionNumber Int       @default(0) // version created when approved
  createdAt     DateTime  @default(now())
}

// ============ Unified repository hub + reusable documentation rule sets ============
// Repository — one connected repository, usable by every workflow (generation,
//              automation, doc sync). Connect once, use everywhere.
// RuleSet    — a reusable documentation-control configuration (same shape as
//              docify.yaml) assignable to any number of repositories.

model Repository {
  id         String    @id @default(cuid())
  userId     String
  provider   String    @default("github") // github | gitlab | bitbucket
  repo       String    // owner/name
  org        String    @default("") // owner segment, for grouping/filtering
  branch     String    @default("main")
  visibility String    @default("unknown") // public | private | unknown
  status     String    @default("unchecked") // connected | unchecked | error
  statusMsg  String    @default("")
  enabled    Boolean   @default(true)
  ruleSetId  String    @default("")
  lastCheck  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model RuleSet {
  id           String   @id @default(cuid())
  userId       String
  name         String
  description  String   @default("")
  config       String   @default("{}") // relevance config JSON: scan / rules / thresholds / product
  instructions String   @default("") // judgment-layer guidance injected into AI stages
  isDefault    Boolean  @default(false)
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Self-monitoring: one health sample every few minutes powers the public
// status page (component states + uptime history). Gaps in samples read as
// downtime — honest by construction.
model StatusSample {
  id   String   @id @default(cuid())
  at   DateTime @default(now())
  ok   Boolean  @default(true)
  dbMs Int      @default(0)
  aiOk Boolean  @default(true)
  note String   @default("")
}

// Tenant writing profile: the organization's voice, terminology, and
// prohibited words. Merged into every generation's resolved writing policy.
model WritingProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String   @default("Organization style")
  guide     String   @default("docify") // docify | microsoft | google | custom
  voice     String   @default("")       // optional formality override
  config    String   @default("{}")     // { terms:[{use,not}], prohibited:[], notes }
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A connected organisation / GitLab group / Bitbucket workspace. Repositories
// from every OrgConnection are aggregated into the unified catalogue that all
// workflow pages consume — connections are managed ONLY on the hub page.
model OrgConnection {
  id        String    @id @default(cuid())
  userId    String
  provider  String    @default("github") // github | gitlab | bitbucket
  org       String    // organisation / group / workspace slug
  status    String    @default("connected") // connected | error
  statusMsg String    @default("")
  repoCount Int       @default(0)
  lastSync  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, provider, org])
}

model RelevanceDecision {
  id         String   @id @default(cuid())
  userId     String
  docId      String   @default("")
  provider   String   @default("github")
  repo       String   @default("")
  sha        String   @default("")
  message    String   @default("")
  author     String   @default("")
  files      String   @default("[]") // changed files JSON
  payload    String   @default("{}") // full commit JSON (for one-click override)
  verdict    String   @default("skip") // document | review | skip
  score      Int      @default(0)
  category   String   @default("")
  rationale  String   @default("")
  stage      String   @default("") // rules | heuristic | ai
  eliminatedBy String @default("")
  surfaces   String   @default("[]")
  overridden Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String
  provider  String
  createdAt DateTime @default(now())
}
