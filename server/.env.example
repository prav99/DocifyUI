DATABASE_URL="file:./dev.db"
JWT_SECRET="set-a-long-random-string"
PORT=4000

# ---------------------------------------------------------------------------
# Support / contact
# ---------------------------------------------------------------------------
# Mailbox that receives customer contact-form submissions.
SUPPORT_EMAIL="support@docifydocai.com"

# ---------------------------------------------------------------------------
# Outbound email (SMTP) — used by the contact form and account emails.
# Get these from your mail provider (e.g. Zoho Mail). Leave blank in local dev:
# the mailer then logs messages to the server console instead of sending.
# NEVER commit real values — this file is an example; real secrets go in the
# untracked server/.env (and in Railway's Variables, not the repo).
# ---------------------------------------------------------------------------
SMTP_HOST="smtp.zoho.com"
SMTP_PORT=587
SMTP_USER="support@docifydocai.com"
SMTP_PASS=""
SMTP_FROM="DocGen Support <support@docifydocai.com>"
